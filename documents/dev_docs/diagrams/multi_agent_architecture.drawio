          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- RACE STATE (Pydantic BaseModel in N31) -->
        <mxCell id="rs" value="&lt;b&gt;RaceState&lt;/b&gt; (Pydantic BaseModel — validated before agents)&#xa;lap_number · gp_name · driver · position · gaps · weather · tyre_data · stint_sequence · fuel_load · radio_msgs · rcm_events · risk_tolerance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="350" width="1050" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e_rsm_rs" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rsm" target="rs" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SUB-AGENTS LABEL -->
        <mxCell id="lbl_agents" value="SUB-AGENTS" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="425" width="360" height="30" as="geometry" />
        </mxCell>

        <!-- N25 Pace Agent -->
        <mxCell id="n25" value="&lt;b&gt;N25 — Pace Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_pace&#xa;@tool get_session_median&#xa;─────────────&#xa;Model: XGBoost N06&#xa;Bootstrap CI N=200&#xa;Output: PaceOutput&#xa;lap_time_pred, ci_p10/p90&#xa;reasoning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N26 Tire Agent -->
        <mxCell id="n26" value="&lt;b&gt;N26 — Tire Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_tire_deg&#xa;@tool estimate_cliff&#xa;─────────────&#xa;Models: TCN N09&#xa;+ MC Dropout N10 (N=50)&#xa;Output: TireOutput&#xa;cliff_lap, p10/p50/p90&#xa;warning_level, reasoning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="245" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N27 Situation Agent -->
        <mxCell id="n27" value="&lt;b&gt;N27 — Race Situation&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_overtake&#xa;@tool predict_sc&#xa;─────────────&#xa;Models: LightGBM N12 + N14&#xa;Platt calibrated&#xa;Output: RaceSituationOutput&#xa;overtake_prob, sc_prob_3lap&#xa;reasoning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N28 Pit Strategy Agent -->
        <mxCell id="n28" value="&lt;b&gt;N28 — Pit Strategy&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_pit_dur&#xa;@tool predict_undercut&#xa;─────────────&#xa;Models: HistGBT N15&#xa;+ LightGBM N16&#xa;Deps: PaceOutput (N25)&#xa;+ TireOutput (N26)&#xa;reasoning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="615" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N29 Radio Agent — NLP-first synthesizer (NOT LangGraph ReAct) -->
        <mxCell id="n29" value="&lt;b&gt;N29 — Radio Agent&lt;/b&gt;&#xa;NLP-first synthesizer&#xa;(N06 pattern + Pydantic v2)&#xa;─────────────&#xa;Stage 1: NLP N24&#xa;(Sentiment/Intent/NER)&#xa;Stage 2: RCM parser&#xa;Stage 3: _build_alerts()&#xa;Stage 4: structured LLM&#xa;RadioSynthesis (Pydantic)&#xa;Output: RadioOutput&#xa;alerts, corrections, reasoning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="460" width="170" height="175" as="geometry" />
        </mxCell>

        <!-- N30 RAG Agent -->
        <mxCell id="n30" value="&lt;b&gt;N30 — RAG Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool query_rag&#xa;(multi-query)&#xa;─────────────&#xa;Stack: Qdrant +&#xa;BGE-M3 + FIA PDFs&#xa;2023-25 · 2,279 chunks&#xa;Output: RegulationContext&#xa;answer, articles[]&#xa;reasoning (= answer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="985" y="460" width="170" height="175" as="geometry" />
        </mxCell>

        <!-- RaceState → Sub-agents -->
        <mxCell id="e_rs_n25" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rs" target="n25" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rs_n26" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rs" target="n26" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rs_n27" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rs" target="n27" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rs_n28" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rs" target="n28" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rs_n29" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rs" target="n29" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rs_n30" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rs" target="n30" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Cross-agent dependencies: N25+N26 → N28 -->
        <mxCell id="e_n25_n28" value="PaceOutput" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#FF6600;fontColor=#FF6600;fontSize=9;" edge="1" source="n25" target="n28" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="145" y="660" />
              <mxPoint x="145" y="680" />
              <mxPoint x="700" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_n26_n28" value="TireOutput" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#FF6600;fontColor=#FF6600;fontSize=9;" edge="1" source="n26" target="n28" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="670" />
              <mxPoint x="330" y="690" />
              <mxPoint x="700" y="690" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Event-triggered RAG: N27+N29 → N30 -->
        <mxCell id="e_n27_n30" value="sc_prob&gt;0.3" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;fontColor=#9673a6;fontSize=9;" edge="1" source="n27" target="n30" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="515" y="660" />
              <mxPoint x="515" y="700" />
              <mxPoint x="1070" y="700" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_n29_n30" value="PROBLEM/ORDER" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;fontColor=#9673a6;fontSize=9;" edge="1" source="n29" target="n30" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- N31 ORCHESTRATOR — 3-layer architecture -->
        <mxCell id="n31" value="&lt;b&gt;N31 — Strategy Orchestrator&lt;/b&gt; (3-layer architecture · LangGraph multi-agent supervisor)&#xa;Layer 1 — MoE-style dynamic routing: always N25+N26+N27 · N28 if N29.alerts or N26.warning_level==PIT_SOON · N30 if sc_prob&gt;0.3 or PROBLEM intent&#xa;Layer 2 — Monte Carlo simulation (N=500): samples pace/cliff/SC/pit/undercut → E[S], P10[S], P90[S] per strategy · score = α·E[S] + (1-α)·P10[S]&#xa;Layer 3 — LLM synthesis (Pydantic structured output): aggregates sub-agent reasonings + MC scores · N30 = hard constraint (filters illegal options)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="730" width="840" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e_n25_n31" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n25" target="n31" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_n26_n31" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n26" target="n31" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_n27_n31" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n27" target="n31" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_n28_n31" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n28" target="n31" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_n29_n31" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n29" target="n31" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_n30_n31" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n30" target="n31" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- OUTPUT -->
        <mxCell id="output" value="&lt;b&gt;StrategyRecommendation&lt;/b&gt; (Pydantic BaseModel)&#xa;action: STAY_OUT / PIT_NOW / UNDERCUT / OVERCUT / ALERT&#xa;reasoning (LLM narrative) · confidence · scenario_scores (MC simulation) · regulation_context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;strokeColor=#BD7000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="910" width="680" height="70" as="geometry" />
