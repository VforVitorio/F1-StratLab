        </mxCell>
        <mxCell id="e_live_rsm" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="live" target="rsm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════════════════════════════════════════ -->
        <!-- RACE STATE -->
        <!-- ════════════════════════════════════════ -->
        <mxCell id="rs" value="&lt;b&gt;RaceState&lt;/b&gt; (shared context, updated each lap)&#xa;lap_number · gp_name · driver · position · gaps · weather · tyre_data · stint_sequence · fuel_load · radio_msgs · rcm_events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="350" width="1050" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e_rsm_rs" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rsm" target="rs" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════════════════════════════════════════ -->
        <!-- SUB-AGENTS -->
        <!-- ════════════════════════════════════════ -->
        <mxCell id="lbl_agents" value="SUB-AGENTS (LangGraph ReAct agents)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="425" width="360" height="30" as="geometry" />
        </mxCell>

        <!-- N25 Pace Agent -->
        <mxCell id="n25" value="&lt;b&gt;N25 — Pace Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_pace&#xa;@tool get_session_median&#xa;─────────────&#xa;Model: XGBoost N06&#xa;Context: prev_lap_time,&#xa;speed_trap, weather,&#xa;fuel_load, compound,&#xa;tyre_life" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N26 Tire Agent -->
        <mxCell id="n26" value="&lt;b&gt;N26 — Tire Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_tire_deg&#xa;@tool estimate_cliff&#xa;─────────────&#xa;Models: TCN N09&#xa;+ MC Dropout N10&#xa;Context: stint_seq[],&#xa;tyre_life[], deg_rate[],&#xa;compound" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="245" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N27 Situation Agent -->
        <mxCell id="n27" value="&lt;b&gt;N27 — Race Situation&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_overtake&#xa;@tool predict_sc&#xa;─────────────&#xa;Models: LightGBM&#xa;N12 + N14&#xa;Context: gap_ahead,&#xa;position, DRS,&#xa;track_status,&#xa;lap_time_std_z" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N28 Pit Strategy Agent -->
        <mxCell id="n28" value="&lt;b&gt;N28 — Pit Strategy&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool predict_pit_dur&#xa;@tool predict_undercut&#xa;─────────────&#xa;Models: HistGBT N15&#xa;+ LightGBM N16&#xa;Context: gap_ahead,&#xa;tyre_life, team +&#xa;&lt;i&gt;PaceOutput (N25)&#xa;TireOutput (N26)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="615" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N29 Radio Agent -->
        <mxCell id="n29" value="&lt;b&gt;N29 — Radio Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool process_radio&#xa;@tool process_rcm&#xa;─────────────&#xa;Model: NLP pipeline&#xa;N24&#xa;Context: radio_msgs[],&#xa;rcm_events[]&#xa;(time window)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="460" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- N30 RAG Agent -->
        <mxCell id="n30" value="&lt;b&gt;N30 — RAG Agent&lt;/b&gt;&#xa;LangGraph ReAct&#xa;─────────────&#xa;@tool query_rag&#xa;(multi-query)&#xa;─────────────&#xa;Stack: Qdrant +&#xa;sentence-transformers&#xa;+ FIA PDFs 2023-25&#xa;Context: event_type&#xa;from N27 / N29" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="985" y="460" width="170" height="160" as="geometry" />
        </mxCell>

