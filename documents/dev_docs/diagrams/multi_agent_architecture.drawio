        <mxCell id="n31_l1" value="&lt;b&gt;Layer 1 — Dynamic MoE Routing&lt;/b&gt;&lt;br/&gt;Always: N25 + N26 + N27 + N29&lt;br/&gt;N29.alerts PROBLEM/WARNING → N28&lt;br/&gt;N26.warning_level == PIT_SOON → N28&lt;br/&gt;N27.sc_prob_3lap &gt; 0.3 → N30&lt;br/&gt;N29.alerts PENALTY/WARNING → N30&lt;br/&gt;N28 active → N30 (constraint check)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8d5f5;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="62" y="682" width="295" height="136" as="geometry" />
        </mxCell>

        <mxCell id="n31_l2" value="&lt;b&gt;Layer 2 — Monte Carlo Simulation&lt;/b&gt;&lt;br/&gt;N_SIM = 500 · per strategy candidate&lt;br/&gt;pace_i ~ N(N25.pred, σ_ci)&lt;br/&gt;cliff_i ~ Triangular(N26.p10/p50/p90)&lt;br/&gt;sc_i ~ Bernoulli(N27.sc_prob_3lap)&lt;br/&gt;pit_i ~ Triangular(N28.p05/p50/p95)&lt;br/&gt;score = α·E[S] + (1−α)·P10[S]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d8c5ed;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="367" y="682" width="308" height="136" as="geometry" />
        </mxCell>

        <mxCell id="n31_l3" value="&lt;b&gt;Layer 3 — LLM Synthesis&lt;/b&gt;&lt;br/&gt;with_structured_output(StrategyRecommendation)&lt;br/&gt;Input: all sub-agent .reasoning fields&lt;br/&gt;+ MC scenario_scores&lt;br/&gt;+ N30.articles (hard constraint)&lt;br/&gt;N30 filters illegal options BEFORE LLM&lt;br/&gt;Output: Pydantic StrategyRecommendation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8b0e0;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="685" y="682" width="328" height="136" as="geometry" />
        </mxCell>

        <mxCell id="e_l1_l2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;" edge="1" source="n31_l1" target="n31_l2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
