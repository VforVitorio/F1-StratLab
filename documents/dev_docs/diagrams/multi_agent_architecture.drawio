        <mxCell id="n31_lbl" value="N31 — Strategy Orchestrator (LangGraph multi-agent supervisor · Local/Cloud LLM)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="658" width="990" height="22" as="geometry" />
