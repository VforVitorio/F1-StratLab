<mxfile host="app.diagrams.net">
  <diagram id="n28" name="N28 — Pit Strategy Agent">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="N28 — Pit Strategy Agent" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="20" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- INPUT ROW — 3 boxes -->
        <mxCell id="in_ctx" value="&lt;b&gt;context_slice&lt;/b&gt;&lt;br/&gt;gap_ahead · position&lt;br/&gt;team · year · circuit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="in_pace" value="&lt;b&gt;PaceOutput (N25)&lt;/b&gt;&lt;br/&gt;lap_time_pred&lt;br/&gt;ci_p10 / ci_p90" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="in_tire" value="&lt;b&gt;TireOutput (N26)&lt;/b&gt;&lt;br/&gt;tyre_life · cliff_lap&lt;br/&gt;warning_level" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="70" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- AGENT -->
        <mxCell id="agent" value="&lt;b&gt;LangGraph ReAct Agent&lt;/b&gt;&lt;br/&gt;LM Studio local LLM&lt;br/&gt;Iterative tool calls until convergence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="295" y="210" width="310" height="70" as="geometry" />
        </mxCell>

        <!-- TOOL 1 -->
        <mxCell id="tool1" value="&lt;b&gt;predict_pit_duration_tool&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Model: HistGBT N15&lt;/i&gt;&lt;br/&gt;Quantile regression P05/P50/P95&lt;br/&gt;→ physical_stop_est [2–4.5s]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="365" width="210" height="85" as="geometry" />
        </mxCell>

        <!-- TOOL 2 -->
        <mxCell id="tool2" value="&lt;b&gt;score_undercut_tool&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Model: LightGBM N16&lt;/i&gt;&lt;br/&gt;Platt calibrated&lt;br/&gt;→ undercut_prob" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="345" y="365" width="210" height="85" as="geometry" />
        </mxCell>

        <!-- TOOL 3 -->
        <mxCell id="tool3" value="&lt;b&gt;get_pit_context_tool&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Circuit + team stats&lt;/i&gt;&lt;br/&gt;Circuit traversal lookup&lt;br/&gt;→ pit_delta, team rates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="630" y="365" width="210" height="85" as="geometry" />
        </mxCell>

        <!-- OUTPUT -->
        <mxCell id="output" value="&lt;b&gt;PitStrategyOutput&lt;/b&gt;&lt;br/&gt;p05/p50/p95_duration · undercut_prob · recommended_action · reasoning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="280" y="525" width="340" height="60" as="geometry" />
        </mxCell>

        <!-- NOTE -->
        <mxCell id="note" value="→ N31 Strategy Orchestrator (MC simulation samples p05/p50/p95 + undercut_prob)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="603" width="540" height="20" as="geometry" />
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="in_ctx" target="agent" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d79b00;" edge="1" source="in_pace" target="agent" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#d79b00;" edge="1" source="in_tire" target="agent" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
